# Deep Analyst — Environment Configuration
# Copy this file to .env and fill in your API keys.

# Required: OpenAI API key for all PaperBanana agents (text + image)
OPENAI_API_KEY=sk-...

# Optional: Override defaults
# TEXT_MODEL=gpt-4o-mini
# IMAGE_MODEL=gpt-image-1
# IMAGE_SIZE=1536x1024
# IMAGE_QUALITY=high
# MAX_CRITIC_ROUNDS=2
