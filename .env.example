# Deep Analyst — Environment Configuration
# Copy this file to .env and fill in your API keys.

# Required: OpenAI API key for image generation (Illustrator agent)
OPENAI_API_KEY=sk-...

# Optional: Override image generation defaults
# IMAGE_MODEL=gpt-image-1
# IMAGE_SIZE=1024x1024
# IMAGE_QUALITY=medium
# CANDIDATES_PER_DIAGRAM=3
