#!/usr/bin/env python3
"""
Deterministic Pipeline Runner for deep-analyst research pipeline.

Replaces the LLM-based Research Orchestrator with a Python state machine.
The Copilot agent calls this script in a loop and follows its JSON instructions.

Usage:
    python3 .github/scripts/pipeline_runner.py init <base_folder>
    python3 .github/scripts/pipeline_runner.py next <base_folder>
    python3 .github/scripts/pipeline_runner.py status <base_folder>
"""

import json
import sys
import re
import os
import shutil
from pathlib import Path
from datetime import datetime


# ═══════════════════════════════════════════════════════════════
# TRANSLITERATION & SLUGIFY
# ═══════════════════════════════════════════════════════════════

_TRANSLIT = {
    'а': 'a', 'б': 'b', 'в': 'v', 'г': 'g', 'д': 'd', 'е': 'e', 'ё': 'yo',
    'ж': 'zh', 'з': 'z', 'и': 'i', 'й': 'y', 'к': 'k', 'л': 'l', 'м': 'm',
    'н': 'n', 'о': 'o', 'п': 'p', 'р': 'r', 'с': 's', 'т': 't', 'у': 'u',
    'ф': 'f', 'х': 'kh', 'ц': 'ts', 'ч': 'ch', 'ш': 'sh', 'щ': 'shch',
    'ъ': '', 'ы': 'y', 'ь': '', 'э': 'e', 'ю': 'yu', 'я': 'ya',
}


def slugify(text: str) -> str:
    """Convert text to folder-safe slug. Handles Cyrillic via transliteration."""
    text = text.lower().strip()
    result = []
    for ch in text:
        if ch in _TRANSLIT:
            result.append(_TRANSLIT[ch])
        elif ch.isascii():
            result.append(ch)
    text = ''.join(result)
    text = re.sub(r'[^a-z0-9]+', '_', text)
    return text.strip('_')[:60]


# ═══════════════════════════════════════════════════════════════
# HELPERS
# ═══════════════════════════════════════════════════════════════

def count_urls(path: Path) -> int:
    if not path.exists():
        return 0
    return len(re.findall(r'https?://', path.read_text(encoding='utf-8')))


def word_count(path: Path) -> int:
    if not path.exists():
        return 0
    return len(path.read_text(encoding='utf-8').split())


def get_subtopic_dirs(base: Path) -> list:
    research = base / "research"
    if not research.exists():
        return []
    return sorted([
        d for d in research.iterdir()
        if d.is_dir() and d.name != "_plan"
    ])


def parse_params(base: Path) -> dict:
    """Parse research/_plan/params.md into a dict."""
    params_file = base / "research" / "_plan" / "params.md"
    if not params_file.exists():
        return {}
    text = params_file.read_text(encoding='utf-8')
    params = {}

    for line in text.splitlines():
        m = re.match(r'-\s+\*\*(.+?)\*\*:\s*(.+)', line)
        if m:
            key = m.group(1).strip().lower()
            val = m.group(2).strip()
            params[key] = val

    # Normalize max_pages
    for key in ['max pages', 'max_pages', 'максимум страниц', 'страниц']:
        if key in params:
            m2 = re.search(r'(\d+)', params[key])
            if m2:
                params['max_pages'] = int(m2.group(1))

    # Parse subtopics
    subtopics = []
    in_sub = False
    for line in text.splitlines():
        if re.search(r'##\s*(Subtopics|Подтемы)', line, re.IGNORECASE):
            in_sub = True
            continue
        if in_sub:
            m3 = re.match(r'\s*\d+\.\s+(.+)', line)
            if m3:
                subtopics.append(m3.group(1).strip())
            elif line.strip().startswith('#'):
                break
    params['subtopics'] = subtopics
    params['topic'] = params.get('topic', params.get('тема', params.get('theme', 'Research')))

    return params


def parse_toc_sections(base: Path) -> list:
    """Parse toc.md into a list of section dicts."""
    toc_file = base / "research" / "_plan" / "toc.md"
    if not toc_file.exists():
        return []
    text = toc_file.read_text(encoding='utf-8')
    sections = []
    current = None

    for line in text.splitlines():
        m = re.match(r'##\s+0*(\d+)\.\s+(.+)', line)
        if m:
            if current:
                sections.append(current)
            num = m.group(1).zfill(2)
            rest = m.group(2)

            # Title: everything before any metadata marker
            title = re.split(r'\s*[—–-]\s*(?:Pages?|Стр|Sources?|Источник)', rest, flags=re.IGNORECASE)[0].strip()

            # Pages
            pm = re.search(r'(?:Pages?|Стр|pages?|стр)[:\s]*(\d+)', rest, re.IGNORECASE)
            pages = int(pm.group(1)) if pm else 2

            # Sources
            sm = re.search(r'(?:Sources?|Источник\w*)[:\s]*(.+?)(?:\s*[—–-]|$)', rest, re.IGNORECASE)
            sources = sm.group(1).strip() if sm else ""

            slug = slugify(title)
            current = {
                "num": num,
                "title": title,
                "pages": pages,
                "words": pages * 300,
                "sources": sources,
                "filename": f"{num}_{slug}.md",
                "slug": slug,
            }
        elif current:
            pm = re.match(r'\s*(?:Pages?|Стр|pages?|стр)[:\s]*(\d+)', line, re.IGNORECASE)
            if pm:
                current["pages"] = int(pm.group(1))
                current["words"] = current["pages"] * 300
            sm = re.match(r'\s*(?:Sources?|Источник\w*)[:\s]*(.+)', line, re.IGNORECASE)
            if sm:
                current["sources"] = sm.group(1).strip()

    if current:
        sections.append(current)
    return sections


def parse_verdict(base: Path) -> str:
    review = base / "draft" / "_review.md"
    if not review.exists():
        return "NONE"
    text = review.read_text(encoding='utf-8')
    if re.search(r'Verdict.*APPROVED', text, re.IGNORECASE):
        return "APPROVED"
    if re.search(r'Verdict.*REVISE', text, re.IGNORECASE):
        return "REVISE"
    if re.search(r'Verdict.*REJECTED', text, re.IGNORECASE):
        return "REJECTED"
    return "UNKNOWN"


def find_section_file(sections_dir: Path, num: str) -> Path | None:
    """Find a section file by number prefix (handles naming variations)."""
    if not sections_dir.exists():
        return None
    for f in sections_dir.glob("*.md"):
        if f.stem.startswith(num) or f.stem.startswith(str(int(num))):
            return f
    return None


def load_retries(base: Path) -> dict:
    f = base / ".retries.json"
    if f.exists():
        return json.loads(f.read_text())
    return {}


def save_retries(base: Path, retries: dict):
    (base / ".retries.json").write_text(json.dumps(retries))


def can_retry(base: Path, key: str, max_retries: int = 1) -> bool:
    """Check if we can retry this validation. Increments counter if yes."""
    retries = load_retries(base)
    count = retries.get(key, 0)
    if count >= max_retries:
        return False
    retries[key] = count + 1
    save_retries(base, retries)
    return True


def revision_count(base: Path) -> int:
    return len(list(base.glob("draft/_review_v*.md")))


# ═══════════════════════════════════════════════════════════════
# PROMPT BUILDERS
# ═══════════════════════════════════════════════════════════════

def prompt_retriever(base: Path, subtopic_name: str, subtopic_slug: str) -> str:
    return f"""BASE_FOLDER: {base}
Search for URLs about: "{subtopic_name}"
Write results to: research/{subtopic_slug}/_links.md

RULES:
- Find 8-10 high-quality URLs about this specific topic
- Format: one URL per line, numbered: "1. https://example.com — Description"
- Prioritize: official docs, engineering blogs, technical deep-dives
- Avoid: marketing pages, landing pages, generic overviews"""


def prompt_extractor(base: Path, subtopic_name: str, subtopic_slug: str) -> str:
    return f"""BASE_FOLDER: {base}
Subtopic: {subtopic_name}
Read URLs from: research/{subtopic_slug}/_links.md

OUTPUT RULES (MANDATORY — violation = pipeline failure):
1. Write ONE SEPARATE FILE PER URL: extract_1.md for the 1st URL, extract_2.md for the 2nd, etc.
   NEVER combine multiple URLs into one file. If _links.md has 8 URLs → produce 8 files.
2. Each extract file: 2000-4000 words. COPY content verbatim from the source.
   Do NOT summarize. If tavily_extract returns 3000 words, your file must contain ~3000 words.
3. Include ALL code blocks, JSON structures, file paths, CLI commands, config examples VERBATIM.
4. If a URL fails (403/404/timeout), skip it — but continue to the NEXT URL.
5. File header format:
   # Extract: [title]
   Source: [full URL]
   Words: ~[actual count]"""


def prompt_analyst(base: Path, subtopic_slug: str, main_topic: str) -> str:
    return f"""BASE_FOLDER: {base}
Analyze all extracts in: research/{subtopic_slug}/
Write structure analysis to: research/{subtopic_slug}/_structure.md
Overall research topic: "{main_topic}"

Analyze depth of extracted content. Propose document sections from these extracts.
Mark each section depth: DEEP (enough for 2000+ word section) or SHALLOW.
Map which extract files support which proposed sections."""


def prompt_planner(base: Path) -> str:
    return f"""BASE_FOLDER: {base}
Read all research/*/_structure.md files and research/_plan/params.md.
Build unified Table of Contents.
Write to: research/_plan/toc.md

FORMAT for each section (MANDATORY — the pipeline parses this with regex):
## NN. Section Title — Pages: N — Sources: path1, path2, ...

Total pages must match max_pages from params.md (±1).
Each section gets a page budget. Sum of all budgets = max_pages."""


def prompt_writer(base: Path, section: dict, is_revision: bool = False) -> str:
    words = section["words"]
    revision_note = ""
    if is_revision:
        reviews = sorted(base.glob("draft/_review_v*.md"))
        if reviews:
            revision_note = f"""
REVISION MODE: Read {reviews[-1].relative_to(base)} for Critic's feedback.
Address ALL feedback points. This is revision #{len(reviews)}."""

    return f"""BASE_FOLDER: {base}
Write section: {section['num']}. {section['title']}
Page budget: {section['pages']} pages ({words} words) — this is the MINIMUM word count.
Source files: {section['sources']}
Read params from: research/_plan/params.md
Write to: draft/_sections/{section['filename']}{revision_note}

MANDATORY RULES:
1. WORD COUNT: Your section MUST be at least {words} words. Run `wc -w` on your output to verify before finishing.
2. TECHNICAL DEPTH: Include ALL technical details from extracts — code blocks, JSON structures, file paths, CLI commands, config examples. Copy them verbatim into your section. Do NOT paraphrase into vague summaries.
3. ILLUSTRATION PLACEHOLDERS: Include at least 1 placeholder per 2+ page section:
   <!-- ILLUSTRATION: type="architecture|comparison|pipeline|flowchart", section="{section['num']}. {section['title']}", description="Detailed description of what to visualize, minimum 200 characters describing layout, elements, connections" -->
4. NO FILLER: Every sentence must add information. Ban: "мощный", "инновационный", "comprehensive", "революционный"."""


def prompt_editor(base: Path) -> str:
    return f"""BASE_FOLDER: {base}
Merge all draft/_sections/*.md files in ToC order.
Read ToC from: research/_plan/toc.md
Read params from: research/_plan/params.md
Write merged document to: draft/v1.md

RULES:
- Maintain ToC section order (01, 02, 03...)
- Add smooth transitions between sections
- Remove duplicated content (same info in multiple sections → keep fullest version)
- Preserve ALL illustration placeholders (<!-- ILLUSTRATION: ... -->) — do NOT remove them
- Do NOT reduce word count — preserve all technical details from sections"""


def prompt_critic(base: Path, max_pages: int) -> str:
    min_words = int(max_pages * 300 * 0.8)
    return f"""BASE_FOLDER: {base}
Review: draft/v1.md
Parameters: research/_plan/params.md
ToC with budgets: research/_plan/toc.md
Write review to: draft/_review.md

CRITICAL RULES:
1. If total document is <{min_words} words for a {max_pages}-page target, verdict MUST be REVISE.
2. If ANY section mentions concepts without explaining HOW they work internally → REVISE.
3. If filler language detected ("мощный", "инновационный", "comprehensive" without substance) → note it.
4. Check each section's word count against its ToC budget (±15%).
5. Check for same content duplicated across multiple sections.
6. Verdict line format: ## Verdict: APPROVED or ## Verdict: REVISE
7. If REVISE: list specific sections and what's wrong with each."""


def prompt_illustrator(base: Path) -> str:
    return f"""BASE_FOLDER: {base}
Generate illustrations for the final draft: draft/v1.md

STEPS (ALL MANDATORY):
1. Read draft/v1.md, find <!-- ILLUSTRATION: ... --> placeholders.
2. If NO placeholders found: independently identify 3-5 sections needing architecture/comparison/pipeline diagrams.
3. For each illustration: run paperbanana_generate.py with --direct mode and a SHORT 2-4 sentence prompt:
   python3 .github/skills/image-generator/scripts/paperbanana_generate.py "[short prompt]" "{base}/illustrations/diagram_N.png" --direct
4. EMBED every generated PNG in draft/v1.md using replace_string_in_file:
   - If placeholder exists: replace <!-- ILLUSTRATION: ... --> with ![Рис. N](../illustrations/diagram_N.png)
   - If no placeholder: find the section's H2 heading, find the first empty line after the first paragraph, insert the image reference.
5. Write manifest to: illustrations/_manifest.md
6. VERIFY: Read draft/v1.md and grep for '.png'. If ZERO matches → YOUR RUN FAILED. Go back and embed."""


def prompt_illustrator_embed(base: Path) -> str:
    return f"""BASE_FOLDER: {base}
URGENT: PNG illustrations exist in illustrations/ but are NOT embedded in draft/v1.md.

Your ONLY task: embed existing PNG files into draft/v1.md.
1. List all .png files in {base}/illustrations/
2. For each PNG, find the relevant section in draft/v1.md (match by topic/name)
3. Use replace_string_in_file to insert ![Рис. N. Caption](../illustrations/filename.png) near the relevant section heading
4. VERIFY: read draft/v1.md and confirm ALL PNGs are referenced with !["""


# ═══════════════════════════════════════════════════════════════
# COMMANDS
# ═══════════════════════════════════════════════════════════════

def cmd_init(base_folder: str) -> dict:
    base = Path(base_folder).resolve()
    (base / "research" / "_plan").mkdir(parents=True, exist_ok=True)
    (base / "draft" / "_sections").mkdir(parents=True, exist_ok=True)
    (base / "illustrations").mkdir(parents=True, exist_ok=True)
    return {
        "status": "ready",
        "folder": str(base),
        "next_step": "Write research/_plan/params.md with: Topic, Max pages, Audience, Tone, Language, and ## Subtopics list. Then run: python3 .github/scripts/pipeline_runner.py next " + str(base),
    }


def cmd_next(base_folder: str) -> dict:
    base = Path(base_folder).resolve()
    if not base.exists():
        return {"action": "error", "message": f"Folder {base} does not exist. Run 'init' first."}

    params = parse_params(base)

    # ── Phase 0: Check params.md ──
    if not params or not params.get('subtopics'):
        return {
            "action": "agent_task",
            "phase": 0,
            "phase_name": "Decomposition",
            "message": "Write research/_plan/params.md. See agent instructions for exact format. Then run 'next' again.",
        }

    main_topic = params.get('topic', 'Research')
    max_pages = params.get('max_pages', 25)
    subtopics = params['subtopics']

    # Ensure subtopic folders exist
    for st in subtopics:
        slug = slugify(st)
        (base / "research" / slug).mkdir(parents=True, exist_ok=True)

    subtopic_dirs = get_subtopic_dirs(base)

    # ── Phase 1: Retrieval ──
    missing_links = [d for d in subtopic_dirs if not (d / "_links.md").exists()]
    if missing_links:
        agents = []
        for d in missing_links:
            agents.append({
                "name": "Retriever",
                "prompt": prompt_retriever(base, d.name.replace('_', ' '), d.name),
                "description": f"Retrieve URLs for {d.name}",
            })
        return {
            "action": "launch_parallel",
            "phase": 1,
            "phase_name": "Retrieval",
            "agent_count": len(agents),
            "agents": agents,
        }

    # ── Validate Phase 1 ──
    weak_links = []
    for d in subtopic_dirs:
        urls = count_urls(d / "_links.md")
        if urls < 3:
            weak_links.append({"subtopic": d.name, "urls": urls})
    if weak_links and can_retry(base, "phase_1_urls"):
        agents = []
        for w in weak_links:
            agents.append({
                "name": "Retriever",
                "prompt": prompt_retriever(base, w["subtopic"].replace('_', ' '), w["subtopic"])
                    + f"\nRETRY: Previous attempt found only {w['urls']} URLs. Broaden your search. Need at least 5.",
                "description": f"Retry retrieval for {w['subtopic']}",
            })
        return {
            "action": "retry",
            "phase": 1,
            "phase_name": "Retrieval (retry — too few URLs)",
            "issues": weak_links,
            "agents": agents,
        }

    # ── Phase 2: Extraction ──
    missing_extracts = [d for d in subtopic_dirs if not list(d.glob("extract_*.md"))]
    if missing_extracts:
        agents = []
        for d in missing_extracts:
            agents.append({
                "name": "Extractor",
                "prompt": prompt_extractor(base, d.name.replace('_', ' '), d.name),
                "description": f"Extract content for {d.name}",
            })
        return {
            "action": "launch_parallel",
            "phase": 2,
            "phase_name": "Extraction",
            "agent_count": len(agents),
            "agents": agents,
        }

    # ── Validate Phase 2 ──
    extract_issues = []
    for d in subtopic_dirs:
        extracts = list(d.glob("extract_*.md"))
        urls = count_urls(d / "_links.md")
        n_ext = len(extracts)
        avg_wc = sum(word_count(e) for e in extracts) / max(n_ext, 1)

        if n_ext < max(int(urls * 0.4), 2) and n_ext < 3:
            extract_issues.append({
                "subtopic": d.name, "extracts": n_ext, "urls": urls,
                "avg_words": int(avg_wc),
                "issue": f"Only {n_ext} extracts from {urls} URLs",
            })
        elif avg_wc < 400:
            extract_issues.append({
                "subtopic": d.name, "extracts": n_ext, "urls": urls,
                "avg_words": int(avg_wc),
                "issue": f"Avg {int(avg_wc)} words/extract — Extractor is summarizing",
            })

    if extract_issues and can_retry(base, "phase_2_quality"):
        agents = []
        for issue in extract_issues:
            agents.append({
                "name": "Extractor",
                "prompt": prompt_extractor(base, issue["subtopic"].replace('_', ' '), issue["subtopic"])
                    + f"\nCRITICAL RETRY: Previous attempt: {issue['extracts']} files, avg {issue['avg_words']} words. "
                    + "Write ONE FILE PER URL. COPY content verbatim. Do NOT summarize.",
                "description": f"Retry extraction for {issue['subtopic']}",
            })
        return {
            "action": "retry",
            "phase": 2,
            "phase_name": "Extraction (retry — quality issues)",
            "issues": extract_issues,
            "agents": agents,
        }

    # ── Phase 3: Analysis ──
    missing_structures = [d for d in subtopic_dirs if not (d / "_structure.md").exists()]
    if missing_structures:
        agents = []
        for d in missing_structures:
            agents.append({
                "name": "Analyst",
                "prompt": prompt_analyst(base, d.name, main_topic),
                "description": f"Analyze {d.name}",
            })
        return {
            "action": "launch_parallel",
            "phase": 3,
            "phase_name": "Analysis",
            "agent_count": len(agents),
            "agents": agents,
        }

    # ── Phase 4: Planning ──
    if not (base / "research" / "_plan" / "toc.md").exists():
        return {
            "action": "launch_single",
            "phase": 4,
            "phase_name": "Planning",
            "agent": "Planner",
            "prompt": prompt_planner(base),
            "description": "Build unified ToC",
        }

    # ── Validate Phase 4 ──
    toc_sections = parse_toc_sections(base)
    if not toc_sections:
        if can_retry(base, "phase_4_parse"):
            (base / "research" / "_plan" / "toc.md").unlink()
            return {
                "action": "retry",
                "phase": 4,
                "phase_name": "Planning (retry — could not parse ToC)",
                "agent": "Planner",
                "prompt": prompt_planner(base) + "\nRETRY: Previous ToC could not be parsed. Use EXACTLY this format: ## NN. Title — Pages: N — Sources: path1, path2",
                "description": "Retry ToC generation",
            }
        return {"action": "error", "message": "ToC exists but cannot be parsed. Check research/_plan/toc.md format."}

    # ── Phase 5: Writing ──
    sections_dir = base / "draft" / "_sections"

    # Find missing sections
    missing_sections = []
    for s in toc_sections:
        found = find_section_file(sections_dir, s["num"])
        if not found:
            missing_sections.append(s)

    is_rev = revision_count(base) > 0

    if missing_sections:
        agents = []
        for s in missing_sections:
            agents.append({
                "name": "Writer",
                "prompt": prompt_writer(base, s, is_revision=is_rev),
                "description": f"Write section {s['num']}",
            })
        return {
            "action": "launch_parallel",
            "phase": 5,
            "phase_name": "Writing" + (" (revision)" if is_rev else ""),
            "agent_count": len(agents),
            "agents": agents,
        }

    # ── Validate Phase 5 ──
    underweight = []
    total_placeholders = 0

    for s in toc_sections:
        f = find_section_file(sections_dir, s["num"])
        if f:
            wc = word_count(f)
            if wc < s["words"] * 0.5:
                underweight.append({
                    "section": f"{s['num']}. {s['title']}",
                    "filename": f.name,
                    "actual_words": wc,
                    "target_words": s["words"],
                })
            total_placeholders += f.read_text(encoding='utf-8').count("<!-- ILLUSTRATION:")

    if underweight and can_retry(base, "phase_5_wordcount"):
        agents = []
        for uw in underweight:
            s = next(x for x in toc_sections if x["num"] == uw["section"][:2])
            # Delete the underweight file so it gets re-created
            bad = find_section_file(sections_dir, s["num"])
            if bad:
                bad.unlink()
            agents.append({
                "name": "Writer",
                "prompt": prompt_writer(base, s, is_revision=is_rev)
                    + f"\nCRITICAL RETRY: Previous output was only {uw['actual_words']} words (target: {uw['target_words']}). "
                    + f"Your section MUST have at least {uw['target_words']} words.",
                "description": f"Retry section {s['num']} (underweight)",
            })
        return {
            "action": "retry",
            "phase": 5,
            "phase_name": "Writing (retry — underweight sections)",
            "issues": underweight,
            "placeholder_count": total_placeholders,
            "agents": agents,
        }

    # ── Phase 6: Editing ──
    if not (base / "draft" / "v1.md").exists():
        return {
            "action": "launch_single",
            "phase": 6,
            "phase_name": "Editing",
            "agent": "Editor",
            "prompt": prompt_editor(base),
            "description": "Merge sections into v1.md",
            "info": {
                "total_placeholders": total_placeholders,
                "section_count": len(toc_sections),
            },
        }

    # ── Validate Phase 6 ──
    draft_wc = word_count(base / "draft" / "v1.md")
    target_words = max_pages * 300

    if draft_wc < target_words * 0.4 and can_retry(base, "phase_6_wordcount"):
        (base / "draft" / "v1.md").unlink()
        return {
            "action": "retry",
            "phase": 6,
            "phase_name": "Editing (retry — draft too short)",
            "message": f"v1.md has {draft_wc} words (target: {target_words}). Re-merging.",
            "agent": "Editor",
            "prompt": prompt_editor(base) + f"\nCRITICAL: Sections total should be ~{target_words} words. Do NOT lose content during merge.",
            "description": "Retry merge (draft was too short)",
        }

    # ── Phase 7: Review ──
    review_file = base / "draft" / "_review.md"
    if not review_file.exists():
        return {
            "action": "launch_single",
            "phase": 7,
            "phase_name": "Review",
            "agent": "Critic",
            "prompt": prompt_critic(base, max_pages),
            "description": "Review draft v1.md",
            "info": {"draft_words": draft_wc, "target_words": target_words},
        }

    # ── Handle Verdict ──
    verdict = parse_verdict(base)

    if verdict in ("REVISE", "REJECTED"):
        rev_count = revision_count(base)
        if rev_count >= 2:
            # Max revisions reached — proceed to illustrations
            pass
        else:
            # Archive review, clean up for re-run
            shutil.copy(review_file, base / "draft" / f"_review_v{rev_count + 1}.md")
            review_file.unlink()
            (base / "draft" / "v1.md").unlink(missing_ok=True)
            # Delete all section files to force Writers to re-run
            for f in (base / "draft" / "_sections").glob("*.md"):
                f.unlink()
            # Recursive call — state machine now sees: no sections → Phase 5
            return cmd_next(base_folder)

    # ── Phase 8: Illustration ──
    draft_text = (base / "draft" / "v1.md").read_text(encoding='utf-8')
    has_png_refs = bool(re.search(r'!\[.*?\]\(.*?\.png\)', draft_text))
    manifest = base / "illustrations" / "_manifest.md"

    if not manifest.exists():
        has_key = bool(os.environ.get("OPENAI_API_KEY"))
        if not has_key:
            return {
                "action": "warning",
                "phase": 8,
                "phase_name": "Illustration (skipped)",
                "message": "OPENAI_API_KEY not set. Skipping illustrations. Proceeding to delivery.",
                "proceed": True,
            }
        return {
            "action": "launch_single",
            "phase": 8,
            "phase_name": "Illustration",
            "agent": "Illustrator",
            "prompt": prompt_illustrator(base),
            "description": "Generate and embed illustrations",
        }

    # Validate Phase 8: PNGs embedded?
    pngs = list((base / "illustrations").glob("*.png"))
    if pngs and not has_png_refs:
        if can_retry(base, "phase_8_embed"):
            manifest.unlink()  # Reset to allow re-run
            return {
                "action": "retry",
                "phase": 8,
                "phase_name": "Illustration (retry — PNGs not embedded)",
                "agent": "Illustrator",
                "prompt": prompt_illustrator_embed(base),
                "description": "Embed existing PNGs into v1.md",
            }

    # ── Phase 9: Delivery ──
    extract_count = sum(1 for _ in base.glob("research/*/extract_*.md"))
    section_count = len(toc_sections)
    png_count = len(list((base / "illustrations").glob("*.png")))
    placeholder_count = draft_text.count("<!-- ILLUSTRATION:")

    # Re-read draft for final word count
    final_wc = word_count(base / "draft" / "v1.md")

    return {
        "action": "complete",
        "phase": 9,
        "phase_name": "Delivery",
        "document": str(base / "draft" / "v1.md"),
        "stats": {
            "words": final_wc,
            "pages_approx": round(final_wc / 300, 1),
            "sections": section_count,
            "extracts": extract_count,
            "illustrations_png": png_count,
            "illustrations_embedded": bool(has_png_refs),
            "illustration_placeholders_remaining": placeholder_count,
            "verdict": verdict,
            "revisions": revision_count(base),
        },
    }


def cmd_status(base_folder: str) -> dict:
    """Full pipeline status report."""
    base = Path(base_folder).resolve()
    if not base.exists():
        return {"error": f"Folder {base} does not exist"}

    params = parse_params(base)
    subtopic_dirs = get_subtopic_dirs(base)
    sections_dir = base / "draft" / "_sections"
    v1 = base / "draft" / "v1.md"

    status = {
        "folder": str(base),
        "params": {
            "topic": params.get('topic', '?'),
            "max_pages": params.get('max_pages', '?'),
            "subtopics": len(params.get('subtopics', [])),
        },
        "phases": {},
    }

    # Phase 1
    links_info = {}
    for d in subtopic_dirs:
        links_info[d.name] = count_urls(d / "_links.md")
    status["phases"]["1_retrieval"] = {
        "topics": len(subtopic_dirs),
        "urls_per_topic": links_info,
        "total_urls": sum(links_info.values()),
    }

    # Phase 2
    extract_info = {}
    for d in subtopic_dirs:
        exts = list(d.glob("extract_*.md"))
        extract_info[d.name] = {
            "count": len(exts),
            "words": [word_count(e) for e in exts],
        }
    status["phases"]["2_extraction"] = extract_info

    # Phase 3
    status["phases"]["3_analysis"] = {
        d.name: (d / "_structure.md").exists() for d in subtopic_dirs
    }

    # Phase 4
    toc = parse_toc_sections(base)
    status["phases"]["4_planning"] = {
        "has_toc": (base / "research" / "_plan" / "toc.md").exists(),
        "sections": len(toc),
        "total_pages": sum(s["pages"] for s in toc) if toc else 0,
    }

    # Phase 5
    section_info = {}
    total_pl = 0
    for s in toc:
        f = find_section_file(sections_dir, s["num"])
        if f:
            wc = word_count(f)
            pl = f.read_text(encoding='utf-8').count("<!-- ILLUSTRATION:")
            total_pl += pl
            section_info[s["num"]] = {
                "file": f.name, "words": wc, "target": s["words"],
                "pct": round(wc / max(s["words"], 1) * 100),
                "placeholders": pl,
            }
        else:
            section_info[s["num"]] = {"file": None, "words": 0, "target": s["words"]}
    status["phases"]["5_writing"] = {
        "sections": section_info,
        "total_placeholders": total_pl,
    }

    # Phase 6
    status["phases"]["6_editing"] = {
        "has_draft": v1.exists(),
        "words": word_count(v1),
    }

    # Phase 7
    status["phases"]["7_review"] = {
        "has_review": (base / "draft" / "_review.md").exists(),
        "verdict": parse_verdict(base),
        "revisions": revision_count(base),
    }

    # Phase 8
    pngs = list((base / "illustrations").glob("*.png"))
    draft_text = v1.read_text(encoding='utf-8') if v1.exists() else ""
    status["phases"]["8_illustration"] = {
        "png_files": len(pngs),
        "png_names": [p.name for p in pngs],
        "embedded_refs": len(re.findall(r'!\[.*?\]\(.*?\.png\)', draft_text)),
        "manifest": (base / "illustrations" / "_manifest.md").exists(),
    }

    status["retries"] = load_retries(base)

    return status


# ═══════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════

def main():
    if len(sys.argv) < 2:
        print(json.dumps({
            "error": "Usage: pipeline_runner.py <command> [base_folder]",
            "commands": {
                "init <folder>": "Create folder structure",
                "next <folder>": "Get next pipeline action (call in a loop)",
                "status <folder>": "Full status report",
            }
        }, indent=2))
        sys.exit(1)

    command = sys.argv[1]

    if command == "init":
        if len(sys.argv) < 3:
            ts = datetime.now().strftime("%Y%m%d_%H%M%S")
            folder = f"generated_docs_{ts}"
        else:
            folder = sys.argv[2]
        result = cmd_init(folder)
    elif command in ("next", "status"):
        if len(sys.argv) < 3:
            print(json.dumps({"error": f"Usage: pipeline_runner.py {command} <base_folder>"}))
            sys.exit(1)
        if command == "next":
            result = cmd_next(sys.argv[2])
        else:
            result = cmd_status(sys.argv[2])
    else:
        result = {"error": f"Unknown command: {command}. Use: init, next, status"}

    print(json.dumps(result, ensure_ascii=False, indent=2))


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(json.dumps({"action": "error", "message": f"Script error: {e}"}, ensure_ascii=False))
        sys.exit(1)
